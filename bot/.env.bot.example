# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your-telegram-bot-token-here

# Telegram Proxy (required for restricted networks)
# Example: http://proxy.example.com:8080 or socks5://proxy.example.com:1080
TELEGRAM_PROXY_URL=http://your-proxy-server:port

# LMS API Configuration
LMS_API_BASE_URL=https://lms.example.com/api
LMS_API_KEY=your-lms-api-key-here

# LLM API Configuration
LLM_API_KEY=your-llm-api-key-here
LLM_API_BASE_URL=https://api.llm-provider.com/v1
